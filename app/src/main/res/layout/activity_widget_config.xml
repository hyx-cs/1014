<?xml version="1.0" encoding="utf-8"?>
<!--
    小组件配置页面布局
    用户在此输入 DeepSeek API Key
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#1B1B2F">

    <!-- 图标 -->
    <TextView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:gravity="center"
        android:text="🔷"
        android:textSize="32sp"
        android:layout_marginBottom="8dp" />

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/config_title"
        android:textColor="#E6FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- 副标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="输入你的 DeepSeek API Key，即可在桌面查看余额"
        android:textColor="#99FFFFFF"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:paddingHorizontal="16dp" />

    <!-- API Key 输入框 -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:hint="@string/api_key_hint"
        app:hintTextColor="#66FFFFFF"
        app:boxStrokeColor="#4A90D9"
        app:boxBackgroundColor="#1AFFFFFF"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/api_key_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E6FFFFFF"
            android:textColorHint="#66FFFFFF"
            android:inputType="textPassword"
            android:maxLines="1"
            android:imeOptions="actionDone" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 保存按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/save_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/save"
        android:textSize="16sp"
        android:enabled="false"
        app:cornerRadius="12dp"
        app:backgroundTint="#4A90D9"
        style="@style/Widget.MaterialComponents.Button" />

    <!-- 安全说明 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒 API Key 将加密存储在本地，不会上传到任何服务器"
        android:textColor="#66FFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="24dp" />

</LinearLayout>
