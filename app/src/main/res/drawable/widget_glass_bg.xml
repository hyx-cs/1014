<?xml version="1.0" encoding="utf-8"?>
<!-- iOS 毛玻璃模拟背景 —— RemoteViews 兼容版 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 第1层：阴影基底 -->
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A000000" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- 第2层：半透明毛玻璃基底 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#30FFFFFF"
                android:centerColor="#1AFFFFFF"
                android:endColor="#25FFFFFF"
                android:type="linear" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- 第3层：亮色顶部高光 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#15FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <!-- 第4层：内边框高光线 -->
    <item
        android:left="0.5dp"
        android:right="0.5dp"
        android:top="0.5dp"
        android:bottom="0.5dp">
        <shape android:shape="rectangle">
            <stroke android:width="0.5dp" android:color="#35FFFFFF" />
            <solid android:color="@android:color/transparent" />
            <corners android:radius="27.5dp" />
        </shape>
    </item>

</layer-list>
